# Copy to .env or use .env.local at project root (LexHelmV2/.env.local)

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:password@host/neondb?sslmode=require"

# ── API Auth ──────────────────────────────────────────────────
X_API_TOKEN=your-api-token-here

# ── JWT (Better Auth) ────────────────────────────────────────
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# ── IndianKanoon (legal search) ──────────────────────────────
IK_API_KEY=your-indian-kanoon-token

# ── GCS (artifact storage) ───────────────────────────────────
GCS_ARTIFACTS_BUCKET=lexhelm-artifacts
# GCS_SERVICE_ACCOUNT_INFO={"type":"service_account",...}

# ── AMQP (message queue — future) ────────────────────────────
# AMQP_LAVINMQ_URL=amqps://user:pass@host/vhost

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3003
